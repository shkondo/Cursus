        </mxCell>
        <mxCell id="release" value="2本のフォークを戻す&#10;(mutex unlock x2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ea9999;strokeColor=#b85450;fontColor=#1a1a1a;" vertex="1" parent="1">
